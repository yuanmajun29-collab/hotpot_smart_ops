[Unit]
Description=Hotpot ERP PO Sync (%i)
After=network.target hotpot-hub.service

[Service]
Type=simple
User=hotpot
Group=hotpot
WorkingDirectory=/opt/hotpot_smart_ops
Environment=PYTHONUNBUFFERED=1
ExecStart=/usr/bin/python3 cloud/integrations/erp_bridge.py \
  --store-id %i \
  --hub-url http://127.0.0.1:8088 \
  --mode file --interval 3600 --output demo/data/stores/%i/live/erp_receiving.json
Restart=always
RestartSec=60

[Install]
WantedBy=multi-user.target
