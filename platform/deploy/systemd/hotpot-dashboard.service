[Unit]
Description=Hotpot Operations Dashboard
After=network.target hotpot-hub.service

[Service]
Type=simple
User=hotpot
Group=hotpot
WorkingDirectory=/opt/hotpot_smart_ops
ExecStart=/usr/bin/python3 dashboard/serve.py --host 0.0.0.0 --port 3000
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
