# 企微 Webhook 配置（DEV-414 · BL-03）
# 复制为 .env 或在 systemd / docker-compose 中注入

# 全局兜底（两店共用同一机器人）
# HOTPOT_WECHAT_WEBHOOK=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=YOUR_KEY

# 店级独立机器人（优先级高于全局）
# HOTPOT_WECHAT_WEBHOOK_STORE_YUHUAN=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=YUHUAN_KEY
# HOTPOT_WECHAT_WEBHOOK_STORE_JIAOJIANG=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=JIAOJIANG_KEY

# warn 级是否推手机（首月默认关闭）
HOTPOT_PUSH_WARN=0

# Hub 地址（SLA 脚本默认）
HOTPOT_HUB_URL=http://127.0.0.1:8088
