# PostgreSQL 模式启动
# docker compose --profile postgres up -d
# export HOTPOT_DATABASE_URL=postgresql://hotpot:hotpot_dev@localhost:5432/hotpot_ops

HOTPOT_DATABASE_URL=postgresql://hotpot:hotpot_dev@postgres:5432/hotpot_ops
HOTPOT_ENV=pilot
HOTPOT_AUTH_MODE=strict
HOTPOT_JWT_SECRET=replace-with-32-plus-random-characters
HOTPOT_CORS_ORIGINS=https://ops.example.com
HOTPOT_EDGE_API_KEYS=edge_prod_yuhuan:store_yuhuan,edge_prod_jiaojiang:store_jiaojiang
